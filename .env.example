VERCEL_TOKEN=your_token_here
DEPLOY_ID=your_deployment_id
TEAM_ID=your_team_id

# Stripe (required to run the app locally — checkout, provisioning, webhook, verify)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# /api/verify metering (optional). Free calls/month per merchant before
# usage is reported as billable overage; defaults to 1000 if unset.
VERIFY_FREE_CALLS_PER_MONTH=1000
# Name of a Stripe Billing Meter (dashboard-created) with a metered Price
# attached, added as a second line item on the Merchant Gate subscription.
# Leave unset to keep /api/verify unmetered (free calls still counted/shown,
# nothing billed).
STRIPE_VERIFY_METER_NAME=

# Rider signing keypair (required for /api/rider/issue and /api/rider/verify).
# Generate a fresh ES256 keypair, e.g.:
#   node -e "const c=require('crypto');const{privateKey,publicKey}=c.generateKeyPairSync('ec',{namedCurve:'P-256',publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log(privateKey);console.log(publicKey);"
# Never commit real key values — set them as real env vars only.
RIDER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
RIDER_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional — overrides the default https://agentrider.vercel.app origin used
# in metadata and checkout redirect URLs (e.g. for local dev or a preview deploy)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required for the participant/reputation/task/credit layer —
# see supabase/schema.sql). Use the service role key server-side only;
# every route in src/app/api/** runs server-side, so this is safe here,
# but never expose it via NEXT_PUBLIC_*.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# HMAC secret for signing trust badges (src/lib/badge.ts). Any long random
# string — rotate by changing this value, which invalidates all outstanding
# badges (they're 24h-lived, so this is low-blast-radius).
BADGE_SECRET=change_me_to_a_long_random_string

# Required only for the MCP `spend_credits` tool's "generate" service
# (src/lib/credits.ts), which calls Claude directly.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Platform cut of each task payout in src/lib/tasks.ts completeTask()
# (0.05 = 5%). Requires the 'platform-treasury' participant row seeded in
# supabase/schema.sql to exist. Defaults to 0.05 if unset.
TASK_FEE_RATE=0.05

# Credits buy-in exchange rate (src/lib/credits.ts) — how many AGC $1 buys
# via POST /api/credits/purchase or the purchase_credits MCP tool. Defaults
# to 100 (i.e. $1 = 100 AGC) if unset.
CREDITS_PER_USD=100
